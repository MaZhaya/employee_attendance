# ============================================
# 数据库配置模板
# 使用说明：
#   1. 复制此文件为 db.properties
#   2. 修改为你的真实数据库连接信息
#   3. db.properties 已在 .gitignore 中，不会被上传到 Git
# ============================================

# MySQL JDBC 驱动
jdbc.driver=com.mysql.cj.jdbc.Driver

# 数据库连接地址（修改 localhost:3306 和数据库名）
jdbc.url=jdbc:mysql://localhost:3306/employee_attendance?useSSL=false&serverTimezone=Asia/Shanghai&allowPublicKeyRetrieval=true

# 数据库用户名
jdbc.username=你的用户名

# 数据库密码（⚠️ 不要提交真实密码到 Git！）
jdbc.password=你的密码
